---
import NavLinks from '../components/NavLinks.astro';
import Logo from '../components/Logo.astro';
const { title, active = '', description = 'Daily wildfire danger ratings and 7-day forecasts for Western Colorado, powered by National Fire Danger Rating System data.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="stylesheet" href="/styles.css" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <!-- Google tag (gtag.js) -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-H0FDXLQ32C"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-H0FDXLQ32C');
  </script>
</head>
<body>
  <header>
    <div class="logo">
      <a href="/index.html" aria-label="BeWildfireAware home"><Logo /></a>
    </div>
    <button class="menu-toggle" aria-label="Toggle navigation menu">&#9776;</button>
    <nav>
      <NavLinks active={active} />
    </nav>
  </header>

  <slot />

  <footer>
    <NavLinks />
    <p><a href="/data-sources.html" style="color:#cfe3d2;">About the data</a> · Contact us at: gunnisonbc71@gmail.com</p>
  </footer>
  <script is:inline src="/nav.js"></script>
</body>
</html>
