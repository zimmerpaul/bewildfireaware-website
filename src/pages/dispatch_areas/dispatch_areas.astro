---
import Base from '../../layouts/Base.astro';
---
<Base title="Dispatch Area Map - BeWildfireAware" active="dispatch">
  <main>
    <section class="dispatch-areas" id="dispatch-areas">
      <h2>Dispatch Areas</h2>
      <p>Today's fire danger by Fire Danger Rating Area. Click an area for its full forecast, or choose one from the Dispatch Areas menu above.</p>
    </section>
  </main>

  <div class="map-wrap">
    <div id="danger-map" style="height: 78vh;">
      <noscript>
        <p class="map-noscript">
          The interactive map requires JavaScript. You can still open any dispatch area
          from the Dispatch Areas menu at the top of the page.
        </p>
      </noscript>
    </div>
  </div>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" defer></script>
  <script is:inline src="/map.js" defer></script>
</Base>
