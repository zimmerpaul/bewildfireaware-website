---
// Header lockup: the original BWA mark + two-tone wordmark.
const { showWordmark = true, size = 42 } = Astro.props;
---
<span class="logo-lockup">
  <img src="/images/bwa_logo_150x150px.webp" alt="" width={size} height={size} class="logo-img" />
  {showWordmark && (
    <span class="logo-word">Be<span class="logo-word-wild">Wildfire</span>Aware</span>
  )}
</span>
