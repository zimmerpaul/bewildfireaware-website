---
// Daily AI-generated overview for an FDRA. Renders nothing when no overview
// exists (e.g. builds without ANTHROPIC_API_KEY).
const { ov } = Astro.props;
---
{ov && (
  <section class="overview">
    <h2>Overview</h2>
    <p class="overview-text">{ov.overview}</p>
    <p class="overview-meta">
      Sources: {ov.sources.map((s, i) => (
        <>
          {i > 0 && ' · '}
          {s.url ? <a href={s.url} target="_blank" rel="noopener">{s.name}</a> : s.name}
        </>
      ))}
      <span class="overview-credit"> — overview generated by Claude{ov.generated ? `, ${ov.generated}` : ''}</span>
    </p>
  </section>
)}
